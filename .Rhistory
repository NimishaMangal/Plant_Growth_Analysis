ggplot(avg_growth, aes(x = soil_type, y = treatment, fill = mean_growth)) +
geom_tile(color = "white") +
scale_fill_gradient(low = "#D6EAF8", high = "#1F618D") +
theme_minimal(base_size = 13) +
labs(title = "Average Growth Rate: Soil Type vs Treatment",
x = "Soil Type", y = "Treatment", fill = "Growth Rate") +
theme(plot.title = element_text(face = "bold", hjust = 0.5))
#Growth Rate Trend with Temperature by Treatment
ggplot(data, aes(x = temperature, y = growth_rate, color = treatment)) +
geom_smooth(method = "loess", se = FALSE, size = 1.2) +
theme_minimal(base_size = 14) +
labs(title = "Growth Rate Trend with Temperature by Treatment",
x = "Temperature (°C)", y = "Growth Rate (cm/day)") +
theme(plot.title = element_text(face = "bold", hjust = 0.5))
# Relationship between Growth & Treatment
growth_treat_summary <- data %>%
group_by(treatment) %>%
summarise(mean_growth = mean(growth_rate, na.rm = TRUE))
ggplot(growth_treat_summary, aes(x = treatment, y = mean_growth, fill = treatment)) +
geom_col(width = 0.6, show.legend = FALSE) +
geom_text(aes(label = round(mean_growth, 2)), vjust = -0.5, size = 4) +
theme_minimal(base_size = 14) +
labs(title = "Average Growth Rate by Treatment Type",
x = "Treatment Type", y = "Average Growth Rate (cm/day)") +
theme(plot.title = element_text(face = "bold", hjust = 0.5),
axis.text.x = element_text(angle = 20, hjust = 1))
# 1. Load packages
#install.packages("caret")   # For train/test split & modeling
#install.packages("randomForest") # Random Forest
#install.packages("Metrics")
library(tidyverse)
library(caret)
library(randomForest)
library(dplyr)
library(Metrics)        # for RMSE, MAE
# 2. Load cleaned data
data <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/data/cleaned_plant_growth.csv")
head(data)
# 3. Data preparation
# Convert categorical variables to factors
data$treatment <- as.factor(data$treatment)
data$soil_type <- as.factor(data$soil_type)
# Remove plant_id (not useful for prediction)
data <- data %>% select(-plant_id)
# Check for NA values
colSums(is.na(data))
data <- na.omit(data)
# Split data into training (70%) and test (30%) sets
set.seed(123) # For reproducibility
train_index <- createDataPartition(data$final_height, p=0.8, list=FALSE)
train_data <- data[train_index, ]
test_data <- data[-train_index, ]
# 4. Linear Regression
lm_model <- lm(growth_rate ~ ., data=train_data)
summary(lm_model)
# Predict on test set
lm_pred <- predict(lm_model, newdata=test_data)
# Evaluate Linear Regression
lm_rmse <- sqrt(mean((lm_pred - test_data$growth_rate)^2))
lm_rmse
lm_r2 <- cor(lm_pred, test_data$growth_rate)^2
lm_r2 #Coefficient of Determination
lm_mae <- MAE(lm_pred, test_data$growth_rate)
lm_mae
cat("Linear Model - RMSE:", lm_rmse, " MAE:",lm_mae, " R²:",lm_r2, "\n")
# 5. Random Forest
set.seed(123)
rf_model <- randomForest(growth_rate ~ ., data=train_data, ntree=500 , importance=TRUE)
rf_model
rf_pred <- predict(rf_model, newdata=test_data)
# Evaluate Random Forest
rf_rmse <- sqrt(mean((rf_pred - test_data$growth_rate)^2))
rf_rmse
rf_r2 <- cor(rf_pred, test_data$growth_rate)^2
rf_r2
rf_mae <- MAE(rf_pred, test_data$growth_rate)
cat("Random Forest - RMSE:", rf_rmse, " MAE:", rf_mae ," R²:",rf_r2, "\n")
# Compare Model Performance
results <- data.frame(
Model = c("Linear Regression", "Random Forest"),
RMSE  = c(lm_rmse, rf_rmse),
MAE   = c(lm_mae, rf_mae),
R2    = c(lm_r2, rf_r2)
)
print(results)
# Save predictions for Power BI dashboard
write.csv(data.frame(actual=test_data$growth_rate, predicted=rf_pred),
"C:/Users/Dell/Desktop/Plant_Growth_Analysis/output/growth_Rate_predictions.csv", row.names=FALSE)
