library(tidyverse)
library(caret)
library(randomForest)
library(dplyr)
library(Metrics)        # for RMSE, MAE
# 2. Load cleaned data
data <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/data/cleaned_plant_growth.csv")
head(data)
# 3. Data preparation
# Convert categorical variables to factors
data$treatment <- as.factor(data$treatment)
data$soil_type <- as.factor(data$soil_type)
# Remove plant_id (not useful for prediction)
data <- data %>% select(-plant_id)
# Check for NA values
colSums(is.na(data))
data <- na.omit(data)
# Split data into training (70%) and test (30%) sets
set.seed(123) # For reproducibility
train_index <- createDataPartition(data$final_height, p=0.8, list=FALSE)
train_data <- data[train_index, ]
test_data <- data[-train_index, ]
# 4. Linear Regression
lm_model <- lm(growth_rate ~ ., data=train_data)
summary(lm_model)
# Predict on test set
lm_pred <- predict(lm_model, newdata=test_data)
# Evaluate Linear Regression
lm_rmse <- sqrt(mean((lm_pred - test_data$growth_rate)^2))
lm_rmse
lm_r2 <- cor(lm_pred, test_data$growth_rate)^2
lm_r2 #Coefficient of Determination
lm_mae <- MAE(lm_pred, test_data$growth_rate)
lm_mae
cat("Linear Model - RMSE:", lm_rmse, " MAE:",lm_mae, " R²:",lm_r2, "\n")
# 5. Random Forest
set.seed(123)
rf_model <- randomForest(growth_rate ~ ., data=train_data, ntree=500 , importance=TRUE)
rf_model
rf_pred <- predict(rf_model, newdata=test_data)
# Evaluate Random Forest
rf_rmse <- sqrt(mean((rf_pred - test_data$growth_rate)^2))
rf_rmse
rf_r2 <- cor(rf_pred, test_data$growth_rate)^2
rf_r2
rf_mae <- MAE(rf_pred, test_data$growth_rate)
cat("Random Forest - RMSE:", rf_rmse, " MAE:", rf_mae ," R²:",rf_r2, "\n")
# Compare Model Performance
results <- data.frame(
Model = c("Linear Regression", "Random Forest"),
RMSE  = c(lm_rmse, rf_rmse),
MAE   = c(lm_mae, rf_mae),
R2    = c(lm_r2, rf_r2)
)
print(results)
# Save predictions for Power BI dashboard
write.csv(data.frame(actual=test_data$growth_rate, predicted=rf_pred),
"C:/Users/Dell/Desktop/Plant_Growth_Analysis/output/growth_Rate_predictions.csv", row.names=FALSE)
