# Load libraries
#install.packages(c("tidyverse", "janitor","dplyr"))
library(tidyverse)
library(janitor)
library(dplyr)
# Load dataset
data <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/data/plant_growth_dataset.csv",header = TRUE, stringsAsFactors = FALSE)
# Check data structure
head(data)
str(data)
summary(data)
# Check for missing values
colSums(is.na(data))
#  Fill missing values
data$Final_Height[is.na(data$Final_Height)] <- mean(data$Final_Height, na.rm = TRUE)
data$Humidity[is.na(data$Humidity)] <- mean(data$Humidity, na.rm = TRUE)
data$Temperature[is.na(data$Temperature)] <- mean(data$Temperature , na.rm = TRUE)
data$Chlorophyll_Content[is.na(data$Chlorophyll_Content)] <- mean(data$Chlorophyll_Content, na.rm = TRUE)
# Remove duplicates if any
sum(duplicated(data))
# --- Clean column names again just in case ---
data <- clean_names(data)
#  Handle outliers ( for numeric columns)
# Replace extreme values beyond 1.5*IQR with NA
numeric_cols <- sapply(data, is.numeric)
for (col in names(data)[numeric_cols]) {
Q1 <- quantile(data[[col]], 0.25, na.rm = TRUE)
Q3 <- quantile(data[[col]], 0.75, na.rm = TRUE)
IQR <- Q3 - Q1
lower <- Q1 - 1.5 * IQR
upper <- Q3 + 1.5 * IQR
data[[col]][data[[col]] < lower | data[[col]] > upper] <- NA
}
# Check results
summary(data)
str(data)
# --- Save cleaned dataset for next step ---
write.csv(data, "data/cleaned_plant_growth.csv", row.names = FALSE)
cat("Data cleaning complete! Cleaned file saved as 'data/cleaned_plant_growth.csv'\n")
# Install packages
#install.packages("tidyverse")
#install.packages("ggplot2")
#install.packages("corrplot")
# Load libraries
library(tidyverse)
library(ggplot2)
library(corrplot)
library(dplyr)
# Load cleaned data
data <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/data/cleaned_plant_growth.csv")
# Quick overview of data
str(data)        # Structure of data
summary(data)    # Statistical summary
head(data)       # First few rows
glimpse(data)
#  Univariate Analysis
# Numeric columns
numeric_cols <- c("humidity", "temperature", "watering_frequency",
"sunlight_hours", "chlorophyll_content", "final_height",
"growth_rate")
# Using ggplot for cleaner visuals
for(col in numeric_cols){
ggplot(data, aes_string(x = col)) +
geom_histogram(fill = "#56B4E9", color = "white", bins = 25) +
theme_minimal() +
labs(title = paste("Distribution of", col), x = col, y = "Count") +
theme(plot.title = element_text(face = "bold", hjust = 0.5)) -> p
print(p)
}
# Categorical columns
categorical_cols <- c("treatment", "soil_type")
for(col in categorical_cols){
cat("🪴 Frequency of", col, ":\n")
print(table(data[[col]]))
ggplot(data, aes_string(x = col, fill = col)) +
geom_bar(show.legend = FALSE) +
theme_minimal() +
labs(title = paste("Count of", col), x = col, y = "Frequency") +
theme(axis.text.x = element_text(angle = 20, hjust = 1),
plot.title = element_text(face = "bold", hjust = 0.5)) -> p
print(p)
}
# Bivariate Analysis
#Correlation (Numeric vs Numeric)
cor_matrix <- cor(data[, numeric_cols], use = "complete.obs")
corrplot(cor_matrix, method = "color", type = "full",
tl.col = "black", tl.cex = 0.8,
addCoef.col = "black", number.cex = 0.6)
# Effect of soil type and treatment on growth rate
avg_growth <- data %>%
group_by(soil_type, treatment) %>%
summarise(mean_growth = mean(growth_rate, na.rm = TRUE))
ggplot(avg_growth, aes(x = soil_type, y = treatment, fill = mean_growth)) +
geom_tile(color = "white") +
scale_fill_gradient(low = "#D6EAF8", high = "#1F618D") +
theme_minimal(base_size = 13) +
labs(title = "Average Growth Rate: Soil Type vs Treatment",
x = "Soil Type", y = "Treatment", fill = "Growth Rate") +
theme(plot.title = element_text(face = "bold", hjust = 0.5))
#Growth Rate Trend with Temperature by Treatment
ggplot(data, aes(x = temperature, y = growth_rate, color = treatment)) +
geom_smooth(method = "loess", se = FALSE, size = 1.2) +
theme_minimal(base_size = 14) +
labs(title = "Growth Rate Trend with Temperature by Treatment",
x = "Temperature (°C)", y = "Growth Rate (cm/day)") +
theme(plot.title = element_text(face = "bold", hjust = 0.5))
# Relationship between Growth & Treatment
growth_treat_summary <- data %>%
group_by(treatment) %>%
summarise(mean_growth = mean(growth_rate, na.rm = TRUE))
ggplot(growth_treat_summary, aes(x = treatment, y = mean_growth, fill = treatment)) +
geom_col(width = 0.6, show.legend = FALSE) +
geom_text(aes(label = round(mean_growth, 2)), vjust = -0.5, size = 4) +
theme_minimal(base_size = 14) +
labs(title = "Average Growth Rate by Treatment Type",
x = "Treatment Type", y = "Average Growth Rate (cm/day)") +
theme(plot.title = element_text(face = "bold", hjust = 0.5),
axis.text.x = element_text(angle = 20, hjust = 1))
# Growth Rate vs Environmental Factors
ggplot(data, aes(x = sunlight_hours,
y = growth_rate,
color = treatment)) +
geom_smooth(method = "loess", se = FALSE, size = 1.3) +
theme_minimal(base_size = 14) +
labs(title = "Effect of Sunlight on Growth Rate by Treatment",
x = "Sunlight Hours (per day)",
y = "Growth Rate (cm/day)",
color = "Treatment Type") +
theme(plot.title = element_text(face = "bold", hjust = 0.5),
legend.position = "right",
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank())
