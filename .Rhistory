# ---------------------------------------------------------------
# 🌿 Plant Growth Rate Prediction App
# ---------------------------------------------------------------
# Load required libraries
library(shiny)
library(ggplot2)
library(dplyr)
library(DT)
# --- Load Datasets ---
data_all <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/data/cleaned_plant_growth.csv")
model_data <- read.csv("C:/Users/Dell/Desktop/Plant_Growth_Analysis/output/growth_Rate_predictions.csv")
names(model_data)
head(model_data)
# --- Define UI ---
ui <- fluidPage(
titlePanel(" Effect of Treatment on Plant Growth "),
sidebarLayout(
sidebarPanel(
h4(" Input Plant Conditions"),
# Treatment input (always present)
selectInput(
"treatment", "Select Treatment:",
choices = unique(data_all$treatment),
selected = unique(data_all$treatment)[1]
),
# Sunlight slider
sliderInput(
"sunlight", "Sunlight (hours/day):",
min = min(data_all$sunlight_hours, na.rm = TRUE),
max = max(data_all$sunlight_hours, na.rm = TRUE),
value = mean(data_all$sunlight_hours, na.rm = TRUE)
),
# Conditionally show soil type if exists
uiOutput("soil_ui"),
actionButton("predictBtn", " Predict Growth Rate", class = "btn-success")
),
mainPanel(
h3(" Predicted Growth Result"),
verbatimTextOutput("predicted_growth"),
hr(),
tabsetPanel(
tabPanel(" Prediction Scatter Plot", plotOutput("plot_pred", height = "500px")),
tabPanel(" Data Table", DTOutput("table_data"))
)
)
)
)
# --- Define Server ---
server <- function(input, output, session) {
# --- Dynamic UI for optional inputs ---
output$soil_ui <- renderUI({
if ("soil_type" %in% names(data_all))
selectInput("soil", "Soil Type:", choices = unique(data_all$soil_type))
})
# --- Prediction Logic ---
prediction_result <- eventReactive(input$predictBtn, {
df <- data_all %>% filter(treatment == input$treatment)
# Optional filters
if ("soil_type" %in% names(df) && !is.null(input$soil))
df <- df %>% filter(soil_type == input$soil)
if ("water_ml" %in% names(df) && !is.null(input$water))
df <- df %>% mutate(diff = abs(sunlight_hours - input$sunlight) +
abs(water_ml - input$water))
else
df <- df %>% mutate(diff = abs(sunlight_hours - input$sunlight))
df <- arrange(df, diff)
pred_val <- mean(df$growth_rate, na.rm = TRUE)  # or your model’s logic
paste(" Predicted Growth Rate:", round(pred_val, 2))
})
# --- Display Prediction ---
output$predicted_growth <- renderText({
res <- prediction_result()
if (is.null(res)) return("No prediction yet.")
res
})
# --- Scatter Plot ---
output$plot_pred <- renderPlot({
ggplot(model_data, aes(x = actual, y = predicted)) +
geom_point(color = "darkgreen", size = 3, alpha = 0.7) +
geom_abline(slope = 1, intercept = 0, color = "red", linetype = "dashed") +
labs(title = "Actual vs Predicted Growth",
x = "Actual Growth", y = "Predicted Growth") +
theme_minimal(base_size = 14)
})
# --- Data Table ---
output$table_data <- renderDT({
datatable(model_data, options = list(pageLength = 10, scrollX = TRUE))
})
}
# --- Run App ---
shinyApp(ui, server)
runApp('scripts/04_deploying.R')
